rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Documents collection
    match /documents/{docId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() 
        && isValidId(docId)
        && incoming().userId == request.auth.uid
        && incoming().status in ['uploading', 'parsing', 'extracting', 'indexing', 'completed', 'failed']
        && (incoming().createdAt == request.time || incoming().createdAt is timestamp)
        && (incoming().updatedAt == request.time || incoming().updatedAt is timestamp)
        && incoming().keys().hasAll(['id', 'userId', 'filename', 'status', 'progress', 'message', 'createdAt', 'updatedAt'])
        && incoming().filename is string && incoming().filename.size() <= 255;

      allow update: if isSignedIn() && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && (incoming().updatedAt == request.time || incoming().updatedAt is timestamp)
        && (
          // Action: Progress Update (allow common progress/result fields)
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'progress', 'message', 'updatedAt', 'pageCount', 'text', 'chunks', 'error', 'chunkCount', 'metadata', 'summary']))
        );

      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Connection check
    match /test/connection {
      allow read: if isSignedIn();
    }

    // User profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Chats
    match /chats/{chatId} {
      allow read, write: if isOwner(resource.data.userId || request.resource.data.userId);
      
      match /messages/{messageId} {
        allow read, write: if isSignedIn(); // Simplified for now, relies on parent check in apps
      }
    }
  }
}
